APP_NAME=VCT Tier 1 Predictor API
APP_ENV=dev
FRONTEND_ORIGIN=http://localhost:3000
ENABLE_INTERNATIONAL_EVENTS=true

RECENCY_DECAY_LAMBDA=0.01
MIN_HISTORY_MAPS=20

RAW_DATA_DIR=data/raw
PROCESSED_DATA_DIR=data/processed
SQLITE_DB_PATH=data/processed/vct_tier1.sqlite3
ARTIFACTS_DIR=artifacts
MODEL_ARTIFACTS_DIR=artifacts/models

TRAINING_HISTORY_DAYS=180
TRAINING_RESULTS_PAGES=40
UPCOMING_PAGES=3
DETAIL_SCRAPE_LIMIT=600
